rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "clauichini@gmail.com" || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // ===============================================================
    // Validation Functions
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'department', 'uid']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 20 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.department is string && data.department.size() > 0 && data.department.size() < 100 &&
             data.uid is string;
    }

    function isValidUserSkill(data) {
      return data.keys().hasAll(['userId', 'skillId', 'level', 'yearsOfExperience']) &&
             data.userId is string &&
             data.skillId is string &&
             data.level is number && data.level >= 1 && data.level <= 5 &&
             data.yearsOfExperience is number && data.yearsOfExperience >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (request.resource.data.uid == resource.data.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /skills/{skillId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /userSkills/{userSkillId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUserSkill(request.resource.data);
      allow update: if isAuthenticated() && isValidUserSkill(request.resource.data) && (request.resource.data.userId == resource.data.userId || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
